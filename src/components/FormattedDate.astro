---
interface Props {
	date: Date;
}

const { date } = Astro.props;
const month = date.toLocaleString("en-US", {
	month: "short",
	timeZone: "Asia/Shanghai",
});
const day = date.toLocaleString("en-US", {
	day: "2-digit",
	timeZone: "Asia/Shanghai",
});
const year = date.toLocaleString("en-US", {
	year: "numeric",
	timeZone: "Asia/Shanghai",
});
---

<time datetime={date.toISOString()}>
	{`${month}, ${day}, ${year}`}
</time>
